{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/index.py": {
      "includeFiles": "**/*",
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/api/index.py" }
  ],
  "installCommand": "pip install -r requirements-vercel.txt",
  "git": {
    "deploymentEnabled": {
      "main": true
    }
  }
}
